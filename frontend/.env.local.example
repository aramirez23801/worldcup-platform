# Local development only.
# Copy this file to .env.local and fill in the values from your deployed stack outputs (WorldCupApi and WorldCupAuth). In production the app does not use these:  it reads a config.json that the frontend stack writes at deploy time.

VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
VITE_WS_URL=wss://your-ws-id.execute-api.us-east-1.amazonaws.com/prod
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-app-client-id
VITE_COGNITO_DOMAIN=https://your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_REGION=us-east-1